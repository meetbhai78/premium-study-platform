# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/study_db?retryWrites=true&w=majority

# Authentication Configuration
JWT_SECRET=super_secret_jwt_sign_key_for_study_material_platform_2026
JWT_EXPIRES_IN=7d

# Cloudinary Media Storage Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Default Admin Presets (Runs on Database Seed or Server Startup if no admin exists)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@study.com
ADMIN_PASSWORD=AdminSecurePassword123
ADMIN_MOBILE=9876543210

# Payment Configuration (UPI Details for Manual QR code and deep linking)
UPI_ID=studyplatform@upi
UPI_MERCHANT_NAME=Premium Study Platform
UPI_AMOUNT=99
